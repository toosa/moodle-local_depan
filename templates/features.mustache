{{!
    @template local_depan/features
    
    Features section for landing page

    Context variables:
    * features_title - Section title
    * features - Array of feature objects:
        - title       string
        - description string
        - has_icon    bool  - render FA icon
        - icon        string FA class (e.g. fa-star)
        - has_image   bool  - render <img> as icon
        - image_url   string
        - has_bg      bool  - card has a custom background
        - card_style  string inline CSS for card background
        - has_url     bool  - card is clickable
        - url         string destination URL
}}

<div class="features-section">
    <div class="container">
        <h2 class="section-title"{{#features_title_style}} style="{{{features_title_style}}}"{{/features_title_style}}>{{features_title}}</h2>
        <div class="features-grid">
            {{#features}}
            {{#has_url}}
            <a href="{{url}}" class="feature-card feature-card--link{{#has_bg}} feature-card--custom-bg{{/has_bg}}" {{#card_style}}style="{{{card_style}}}"{{/card_style}}>
            {{/has_url}}
            {{^has_url}}
            <div class="feature-card{{#has_bg}} feature-card--custom-bg{{/has_bg}}" {{#card_style}}style="{{{card_style}}}"{{/card_style}}>
            {{/has_url}}
                {{#has_bg}}<div class="feature-card-overlay"></div>{{/has_bg}}
                <div class="feature-icon">
                    {{#has_icon}}<i class="fa {{icon}}"></i>{{/has_icon}}
                    {{#has_image}}<img class="feature-icon-img" src="{{image_url}}" alt="{{title}}">{{/has_image}}
                </div>
                <h3>{{title}}</h3>
                <p>{{{description}}}</p>
            {{#has_url}}</a>{{/has_url}}
            {{^has_url}}</div>{{/has_url}}
            {{/features}}
        </div>
    </div>
</div>